#!name=Cake Premium Unlock
#!desc=Cake 会员解锁 - 无限红心/AI导师票/全部课程内容
#!home=https://github.com/Leslie159357/Loon-Plugins
#!icon=https://static-mycake.pstatic.net/image/img_2309221549/1695607693176
#!author=Leslie159357
#!date=2026-05-25
#!version=1.0

[URL Rewrite]
# 将所有通往 cakeapp.me 的请求强制走MITM（Loon需要）
^https?://api\.cakeapp\.me https://api.cakeapp.me header

[MITM]
hostname = api.mycake.me, api.cakeapp.me

[Script]
http-response ^https?://api\.mycake\.me/app/start script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/heart\b script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/tutorbot/ticket/policy script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.mycake\.me/v2/main/subscription/channel/updated script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/main/today script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/sentence/\d+/view/contents/extra script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/v2/sentence/\d+/view/relation script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
http-response ^https?://api\.cakeapp\.me/gw/snacks script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Cake/cake.js
