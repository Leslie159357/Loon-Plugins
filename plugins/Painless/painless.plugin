#!name=不背单词 Painless Premium Unlock
#!desc=解锁不背单词VIP会员，全部功能免费使用（v1.1 新增Apple登录拦截）
#!home=https://github.com/Leslie159357/Loon-Plugins
#!icon=https://is1-ssl.mzstatic.com/image/thumb/Purple221/v4/09/ab/86/09ab86d2-44c0-6314-7d91-c943082283cd/AppIcon-1x_U007emarketing-0-7-0-0-0-85-220-0.png/246x0w.webp
#!author=Leslie
#!version=1.1

[MITM]
hostname = %APPEND% app.xiangzi.tech

[URL Rewrite]
# 不背单词 API 全部明文JSON，无需重写

[Script]
http-response ^https:\/\/app\.xiangzi\.tech\/app\/users\/\d+$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Painless/painless.js, requires-body=true, tag=不背单词-用户信息
http-response ^https:\/\/app\.xiangzi\.tech\/app\/login\/appleid script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Painless/painless.js, requires-body=true, tag=不背单词-Apple登录
http-response ^https:\/\/app\.xiangzi\.tech\/app\/painless\/users\/\d+\/rank\/v2\/list script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Painless/painless.js, requires-body=true, tag=不背单词-排行榜
http-response ^https:\/\/app\.xiangzi\.tech\/app\/painless\/users\/\d+\/continuous\/days script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Painless/painless.js, requires-body=true, tag=不背单词-签到
