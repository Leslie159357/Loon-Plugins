# 瓜瓜跟读 Quantumult X 配置
# Bundle ID: com.muyi.linguagua
# API: api.lgg.oranglish.com

[rewrite_remote]
https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Linguagua/linguagua_crack.js, tag=瓜瓜跟读-破解, update-interval=86400, opt-parser=false, enabled=true

[script]
http-response ^https?://api\.lgg\.oranglish\.com/user/info requires-body=1, tag=瓜瓜跟读-用户信息, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Linguagua/linguagua_crack.js
http-response ^https?://api\.lgg\.oranglish\.com/membership/verify/apple/receipt requires-body=1, tag=瓜瓜跟读-收据验证, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Linguagua/linguagua_crack.js
http-response ^https?://api\.lgg\.oranglish\.com/membership/exchange requires-body=1, tag=瓜瓜跟读-兑换码, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Linguagua/linguagua_crack.js
http-response ^https?://api\.lgg\.oranglish\.com/refresh/token requires-body=1, tag=瓜瓜跟读-Token刷新, script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Linguagua/linguagua_crack.js

[mitm]
hostname = api.lgg.oranglish.com
